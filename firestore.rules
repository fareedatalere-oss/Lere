
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
    
    match /users/{userId} { allow read, write: if true; }
    match /transactions/{txId} { allow read, write: if true; }
    match /published_books/{bookId} { allow read, write: if true; }
    match /calls/{callId} { allow read, write: if true; }
    match /messages/{msgId} { allow read, write: if true; }
    match /number_listings/{listId} { allow read, write: if true; }
  }
}
