
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a registered user within the Lere Connect application.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "accountNumber": { "type": "string" },
        "balance": { "type": "number" },
        "rewardBalance": { "type": "number" },
        "pin": { "type": "string" },
        "myReferralCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "phoneNumber", "accountNumber", "balance", "pin", "createdAt"]
    },
    "PublishedBook": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PublishedBook",
      "type": "object",
      "description": "A book published by a user to the global library.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "category": { "type": "string" },
        "publisherId": { "type": "string" },
        "publisherName": { "type": "string" },
        "summary": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "author", "category", "publisherId", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/published_books/{bookId}",
        "definition": {
          "entityName": "PublishedBook",
          "schema": { "$ref": "#/backend/entities/PublishedBook" },
          "description": "Global collection of user-published educational books."
        }
      }
    ]
  }
}
