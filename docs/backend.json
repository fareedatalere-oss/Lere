
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a registered user within the Lere Connect application.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "accountNumber": { "type": "string" },
        "balance": { "type": "number" },
        "rewardBalance": { "type": "number" },
        "pin": { "type": "string" },
        "myReferralCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "customRingtoneUrl": { "type": "string" },
        "faceLoginActive": { "type": "boolean" },
        "voiceLoginActive": { "type": "boolean" },
        "isBlocked": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "freePublishUsed": { "type": "boolean" },
        "publishingSubscriptionExpiry": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "phoneNumber", "accountNumber", "balance", "pin", "createdAt"]
    },
    "PublishedBook": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PublishedBook",
      "type": "object",
      "description": "A book published by a user to the global library.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "category": { "type": "string" },
        "publisherId": { "type": "string" },
        "publisherName": { "type": "string" },
        "summary": { "type": "string" },
        "price": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "author", "category", "publisherId", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "description": "A financial transaction record.",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "charge": { "type": "number" },
        "total": { "type": "number" },
        "recipient": { "type": "string" },
        "status": { "type": "string" },
        "error": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "deletedByUser": { "type": "boolean" }
      }
    },
    "Call": {
      "title": "Call",
      "type": "object",
      "description": "A voice or video call record.",
      "properties": {
        "callerId": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": { "type": "string" },
        "callType": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" }
      }
    },
    "SMSMessage": {
      "title": "SMSMessage",
      "type": "object",
      "description": "A real SMS message sent to a user's line.",
      "properties": {
        "recipientNumber": { "type": "string" },
        "sender": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "NumberListing": {
      "title": "NumberListing",
      "type": "object",
      "description": "A number listed for sale or being purchased.",
      "properties": {
        "userId": { "type": "string" },
        "number": { "type": "string" },
        "nin": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "middleName": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string", "enum": ["sale", "purchase"] },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/published_books/{bookId}",
        "definition": {
          "entityName": "PublishedBook",
          "schema": { "$ref": "#/backend/entities/PublishedBook" },
          "description": "Global collection of user-published educational books."
        }
      },
      {
        "path": "/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "schema": { "$ref": "#/backend/entities/Transaction" },
          "description": "History of financial transactions."
        }
      },
      {
        "path": "/calls/{callId}",
        "definition": {
          "entityName": "Call",
          "schema": { "$ref": "#/backend/entities/Call" },
          "description": "Active and past call records."
        }
      },
      {
        "path": "/messages/{messageId}",
        "definition": {
          "entityName": "SMSMessage",
          "schema": { "$ref": "#/backend/entities/SMSMessage" },
          "description": "Real SMS messages."
        }
      },
      {
        "path": "/number_listings/{listingId}",
        "definition": {
          "entityName": "NumberListing",
          "schema": { "$ref": "#/backend/entities/NumberListing" },
          "description": "Requests to buy or sell numbers."
        }
      }
    ]
  }
}
